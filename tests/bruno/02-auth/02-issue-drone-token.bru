meta {
  name: Issue Drone Token
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/token
  body: json
  auth: none
}

body:json {
  {
    "name": "drone-alpha",
    "role": "drone"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("droneToken", res.body.token);
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("has token", function() {
    expect(res.body.token).to.be.a("string");
  });
  test("role is drone", function() {
    expect(res.body.principal.role).to.equal("drone");
  });
}
