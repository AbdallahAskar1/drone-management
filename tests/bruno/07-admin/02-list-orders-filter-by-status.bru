meta {
  name: Admin — List Orders (filter by status)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/admin/orders?status=delivered
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("all results are delivered", function() {
    res.body.orders.forEach(function(o) {
      expect(o.status).to.equal("delivered");
    });
  });
}
