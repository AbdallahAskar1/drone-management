meta {
  name: Submit Order for Failure Test
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/orders
  body: json
  auth: bearer
}

auth:bearer {
  token: {{userToken}}
}

body:json {
  {
    "origin": { "lat": 25.0, "lng": 55.0 },
    "destination": { "lat": 25.2, "lng": 55.2 }
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("orderId", res.body.id);
  }
}

tests {
  test("status 201", function() {
    expect(res.status).to.equal(201);
  });
}
