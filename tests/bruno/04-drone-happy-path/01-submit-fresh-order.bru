meta {
  name: Submit Fresh Order (for drone flow)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/orders
  body: json
  auth: bearer
}

auth:bearer {
  token: {{userToken}}
}

body:json {
  {
    "origin": { "lat": 30.0, "lng": 31.0 },
    "destination": { "lat": 30.5, "lng": 31.5 }
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("orderId", res.body.id);
  }
}

tests {
  test("status 201", function() {
    expect(res.status).to.equal(201);
  });
}
