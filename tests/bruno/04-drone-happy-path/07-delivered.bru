meta {
  name: Mark Delivered
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/drone/orders/{{orderId}}/delivered
  body: none
  auth: bearer
}

auth:bearer {
  token: {{droneToken}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("order delivered", function() {
    expect(res.body.status).to.equal("delivered");
  });
  test("delivered_at set", function() {
    expect(res.body.delivered_at).to.not.be.null;
  });
}
